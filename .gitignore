# ---------------------------------
# Python Bytecode
# ---------------------------------
__pycache__/
*.py[cod]
*$py.class

# ---------------------------------
# Virtual Environment
# ---------------------------------
venv/
.venv/
ENV/
env/

# ---------------------------------
# Environment Variables
# ---------------------------------
.env
.env.*

# ---------------------------------
# Jupyter Notebook
# ---------------------------------
.ipynb_checkpoints/

# ---------------------------------
# VS Code
# ---------------------------------
.vscode/

# ---------------------------------
# PyCharm
# ---------------------------------
.idea/

# ---------------------------------
# macOS
# ---------------------------------
.DS_Store

# ---------------------------------
# Windows
# ---------------------------------
Thumbs.db
Desktop.ini

# ---------------------------------
# Log Files
# ---------------------------------
logs/
*.log

# ---------------------------------
# Temporary Files
# ---------------------------------
*.tmp
*.bak
*.swp

# ---------------------------------
# Build Files
# ---------------------------------
build/
dist/
*.egg-info/

# ---------------------------------
# Test Cache
# ---------------------------------
.pytest_cache/
.coverage
htmlcov/

# ---------------------------------
# Python Cache
# ---------------------------------
.mypy_cache/
.pyre/
.ruff_cache/

# ---------------------------------
# Generated Data Files
# (Remove these lines if you want
# to upload sample CSV files to GitHub)
# ---------------------------------
data/raw/*.csv
data/processed/*.csv
data/exports/*.csv

# ---------------------------------
# Power BI Cache
# ---------------------------------
*.pbix.autorecovery
*.tmp.pbix

# ---------------------------------
# SQLite Database
# ---------------------------------
*.db
*.sqlite3

# ---------------------------------
# Backup Files
# ---------------------------------
*.zip
*.rar
*.7z

# ---------------------------------
# Reports Generated During Runtime
# ---------------------------------
reports/output/*.csv
reports/output/*.xlsx
reports/output/*.pdf

# ---------------------------------
# Notebook Outputs
# ---------------------------------
*.nbconvert.ipynb